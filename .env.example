# Required
EMAIL=your@email.com
PASSWORD=yourpassword
CUSTOM_ID=your_custom_id
BASE_URL=https://api.example.com

# Optional coordinates sent to the API (affects proximity sorting)
LATITUDE=
LONGITUDE=

# Retry settings
# RETRY_DURATION: total seconds to keep retrying (default: 300)
RETRY_DURATION=300
# RETRY_INTERVAL: seconds between retries (default: 5)
RETRY_INTERVAL=5

# Discord bot (only needed for: cargo run --bin monclub-discord)
# Create a bot at https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token
# Your Discord user ID (right-click your name → Copy User ID with Developer Mode on)
# If unset, all users can trigger commands
DISCORD_OWNER_ID=your_discord_user_id
